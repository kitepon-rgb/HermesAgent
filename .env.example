# X-HERMES-MCP — environment configuration template.
# On the deploy host: cp .env.example .env && chmod 600 .env

# --- Transport ---------------------------------------------------------------
# stdio          : ローカル `.mcp.json` 経由の subprocess (Phase 3 開発時、認証なし)
# streamable-http: Phase 4 本番デプロイ (OAuth 必須)
X_HERMES_MCP_TRANSPORT=streamable-http

# --- HTTP transport bind ------------------------------------------------------
X_HERMES_MCP_HOST=0.0.0.0
X_HERMES_MCP_PORT=65432

# --- OAuth (HTTP transport 必須) ---------------------------------------------
# サーバの公開 URL (Caddy が TLS 終端して指す先)。
# OAuth メタデータ (`/.well-known/oauth-authorization-server` 等) でこれが
# issuer / resource として返るので、外部から見える URL を入れる。
X_HERMES_MCP_BASE_URL=https://hermes.kitepon.dynv6.net

# consent ページで聞かれる master password。MCP クライアント
# (Claude.ai / Claude Code / Codex / ChatGPT) が OAuth dance に来たときに
# ブラウザでこのページが出て、この password を打つと認可される。
# 強い乱数で生成して .env に入れる:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
MCP_ADMIN_PASSWORD=

# OAuth トークン・DCR クライアント・認可コードを保存する SQLite ファイル。
# host の ~/.hermes/ は bind mount されるので、ここに置けば container 再生成
# しても永続化される (= 既存クライアントの再ログイン不要)。
OAUTH_DB_PATH=/home/kite/.hermes/x_hermes_mcp_oauth.db

# --- Hermes binary path inside container -------------------------------------
# host の ~/.hermes/ を同一パスで bind mount するため、venv の本体を直接指す。
HERMES_BIN=/home/kite/.hermes/hermes-agent/venv/bin/hermes
