# X-HERMES-MCP — environment configuration template.
# On the deploy host: cp .env.example .env && chmod 600 .env

# --- Transport ---------------------------------------------------------------
# stdio          : 旧 .mcp.json 経由のローカル subprocess (Phase 3 開発時)
# streamable-http: Phase 4 本番デプロイ
X_HERMES_MCP_TRANSPORT=streamable-http

# --- HTTP transport bind ------------------------------------------------------
# コンテナ内部のバインド。compose で `192.168.1.2:65432:65432` にマップする。
X_HERMES_MCP_HOST=0.0.0.0
X_HERMES_MCP_PORT=65432

# --- Bearer auth (HTTP transport のみ必須) -----------------------------------
# 強い乱数で生成して .env に入れる:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
X_HERMES_MCP_TOKEN=

# --- Hermes binary path inside container -------------------------------------
# host の ~/.hermes/ を同一パスで bind mount するため、venv の本体を直接指す。
# shebang が絶対パスで /home/kite/.hermes/... を要求するので、コンテナ内も
# 同じパスで mount しないと壊れる (重要)。
HERMES_BIN=/home/kite/.hermes/hermes-agent/venv/bin/hermes
